# Server configuration
PORT=8080
HOST_ADDRESS=127.0.0.1
CONTAINER_ADDRESS=0.0.0.0

QWEN_CODE_API_HOST_PORT=42005

# Logging: off, error, debug
LOG_LEVEL=error

# Retry configuration for 500 errors
MAX_RETRIES=5
RETRY_DELAY_MS=1000

# Qwen Code authentication usage
# Set to false to disable using the default ~/.qwen/oauth_creds.json file
QWEN_CODE_AUTH_USE=true

# API Key (optional - if not set, API key validation will be disabled)
# Multiple API keys can be provided as comma-separated values
QWEN_CODE_API_KEY=my-secret-qwen-key

# Docker registry prefix
REGISTRY_PREFIX_DOCKER_HUB=harbor.pg.innopolis.university/docker-hub-cache/
